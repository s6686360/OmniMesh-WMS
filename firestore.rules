rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Default Deny ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Collection Matches ---

    // 1. Operational Collections
    // We allow reading if the technical connection (Anonymous Auth) is established.
    // This fixes the "Missing or insufficient permissions" syncing errors.
    match /receipts/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /returns/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /pickups/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /manifests/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /breakbulks/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /haulierBookings/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /fclTemplates/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /containerBookings/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /commercialInvoices/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /storageEntries/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /storageRates/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /storageZones/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    
    // 2. Master Data
    match /vendorBills/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /costRecoveries/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /masterTariffs/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /locations/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /miscChargeTypes/{id} { allow read: if isSignedIn(); allow write: if isSignedIn(); }
    match /currencies/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /glCodes/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /services/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /csvExportTemplates/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /companies/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /ports/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /warehouses/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /containerTypes/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /users/{id} { allow read: if true; allow write: if isSignedIn(); }
    match /roles/{id} { allow read: if true; allow write: if isSignedIn(); }

    // 3. System & Logs
    match /activityLogs/{id} { allow read, write: if isSignedIn(); }
    match /system/{id} { allow read, write: if isSignedIn(); }
    match /notifications/{id} { 
      allow read, write: if isSignedIn();
    }
  }
}

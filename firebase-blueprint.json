{
  "entities": {
    "Receipt": {
      "title": "Shipment Receipt",
      "description": "Represents a shipment stock-in record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "transactionType": { "type": "string" },
        "company": { "type": "string" },
        "transportArrangement": { "type": "string" },
        "customer": { "type": "string" },
        "consignee": { "type": "string" },
        "consignor": { "type": "string" },
        "pol": { "type": "string" },
        "pod": { "type": "string" },
        "consigneeDeliveryAddress": { "type": "string" },
        "shipperDoNo": { "type": "string" },
        "isUrgent": { "type": "boolean" },
        "sendingType": { "type": "string" },
        "puNo": { "type": "string" },
        "totalQty": { "type": "number" },
        "totalCBM": { "type": "number" },
        "totalWeight": { "type": "number" },
        "lines": { "type": "array" }
      },
      "required": ["id", "date", "customer", "consignee", "consignor"]
    },
    "Return": {
      "title": "Return Note",
      "description": "Represents a return of goods from inventory.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "receiptId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "doNo": { "type": "string" },
        "reason": { "type": "string" },
        "totalReturnQty": { "type": "number" }
      },
      "required": ["id", "receiptId", "date"]
    },
    "Pickup": {
      "title": "Pickup Request",
      "description": "Represents a request to pick up goods from a location.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "customerName": { "type": "string" },
        "consignorName": { "type": "string" },
        "consigneeName": { "type": "string" },
        "pickupPartyName": { "type": "string" },
        "status": { "type": "string" },
        "linkedSid": { "type": "string" },
        "totalQty": { "type": "number" },
        "totalCBM": { "type": "number" },
        "totalWeight": { "type": "number" },
        "lines": { "type": "array" }
      },
      "required": ["id", "date", "customerName", "consignorName"]
    },
    "Manifest": {
      "title": "Manifest",
      "description": "Represents a manifest of cargo loaded into a container or vessel.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "pol": { "type": "string" },
        "pod": { "type": "string" },
        "vessel": { "type": "string" },
        "containerNo": { "type": "string" },
        "status": { "type": "string" },
        "totalCBM": { "type": "number" },
        "totalWeight": { "type": "number" },
        "lines": { "type": "array" }
      },
      "required": ["id", "date", "pol", "pod"]
    },
    "Company": {
      "title": "Company Partner",
      "description": "Represents a business partner (customer, consignee, consignor, transporter, haulier, etc.).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "isCustomer": { "type": "boolean" },
        "isConsignee": { "type": "boolean" },
        "isConsignor": { "type": "boolean" },
        "isTransporter": { "type": "boolean" },
        "isHaulier": { "type": "boolean" }
      },
      "required": ["id", "name"]
    },
    "Port": {
      "title": "Port",
      "description": "Represents a sea or air port.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "country": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Depot": {
      "title": "Container Depot",
      "description": "Represents a container depot assigned to a port.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "portId": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "User": {
      "title": "System User",
      "description": "Represents an application user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "roleId": { "type": "string" },
        "companyId": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "username", "roleId"]
    },
    "Role": {
      "title": "User Role",
      "description": "Represents a set of permissions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "permissions": { "type": "object" }
      },
      "required": ["id", "name"]
    },
    "Warehouse": {
      "title": "Warehouse",
      "description": "Represents a physical storage facility.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "companyId": { "type": "string" }
      },
      "required": ["id", "name", "companyId"]
    },
    "ContainerType": {
      "title": "Container Type",
      "description": "Represents a type of shipping container (e.g., 20GP, 40HC).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "maxCbm": { "type": "number" },
        "maxWeight": { "type": "number" }
      },
      "required": ["id", "type"]
    },
    "FclTemplate": {
      "title": "FCL Cost Template",
      "description": "Represents a template for FCL costs based on route.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "pol": { "type": "string" },
        "pod": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["id", "name", "pol", "pod"]
    },
    "ContainerBooking": {
      "title": "Container Booking",
      "description": "Represents a booking with a shipping line.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pol": { "type": "string" },
        "pod": { "type": "string" },
        "expectedSailingDate": { "type": "string", "format": "date" }
      },
      "required": ["id", "pol", "pod"]
    },
    "HaulierBooking": {
      "title": "Haulier Booking",
      "description": "Represents a booking with a haulier for container movement.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "haulierName": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "haulierName", "status"]
    },
    "CommercialInvoice": {
      "title": "Commercial Invoice",
      "description": "Represents a commercial invoice for custom clearance.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceDate": { "type": "string", "format": "date" },
        "hblNo": { "type": "string" }
      },
      "required": ["id", "invoiceDate"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Represents a log of user actions in the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "action": { "type": "string" },
        "module": { "type": "string" },
        "recordId": { "type": "string" },
        "username": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "action", "module", "username", "date"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Represents a system notification for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" }
      },
      "required": ["id", "userId", "date"]
    },
    "Breakbulk": {
      "title": "Breakbulk Record",
      "description": "Represents a split shipment record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "receiptId": { "type": "string" }
      },
      "required": ["id", "date", "receiptId"]
    },
    "StorageZone": {
      "title": "Storage Zone",
      "description": "Represents a specific area allocation within the warehouse.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "totalArea": { "type": "number" },
        "deadSpaceValue": { "type": "number" },
        "deadSpaceType": { "type": "string" },
        "storageServiceValue": { "type": "number" },
        "storageServiceType": { "type": "string" },
        "fulfillmentValue": { "type": "number" },
        "fulfillmentType": { "type": "string" },
        "lclKivValue": { "type": "number" },
        "lclKivType": { "type": "string" },
        "crossDockValue": { "type": "number" },
        "crossDockType": { "type": "string" }
      },
      "required": ["id", "totalArea"]
    },
    "StorageRate": {
      "title": "Storage Rate",
      "description": "Represents storage pricing configurations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "customerId": { "type": "string" },
        "unitType": { "type": "string" },
        "shortTermRate": { "type": "number" },
        "longTermRate": { "type": "number" },
        "inboundHandling": { "type": "number" },
        "outboundHandling": { "type": "number" }
      },
      "required": ["id", "name", "unitType"]
    },
    "StorageEntry": {
      "title": "Storage Entry",
      "description": "Represents an inbound/outbound record for the storage service.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "dateIn": { "type": "string", "format": "date-time" },
        "dateOut": { "type": "string", "format": "date-time" },
        "customerId": { "type": "string" },
        "isStackable": { "type": "boolean" },
        "palletCount": { "type": "number" },
        "handlingType": { "type": "string" },
        "totalQty": { "type": "number" },
        "totalCbm": { "type": "number" },
        "totalSqft": { "type": "number" },
        "rateId": { "type": "string" },
        "storageTerm": { "type": "string" },
        "inboundCharge": { "type": "number" },
        "mainStorageCharge": { "type": "number" },
        "totalSellingPrice": { "type": "number" },
        "lines": { "type": "array" }
      },
      "required": ["id", "dateIn", "customerId"]
    },
    "VendorBill": {
      "title": "Vendor Bill",
      "description": "Represents a bill from a vendor allocated to manifests or containers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "vendorId": { "type": "string" },
        "manifestId": { "type": "string" },
        "billNo": { "type": "string" },
        "lines": { "type": "array" }
      },
      "required": ["id", "date", "vendorId"]
    },
    "CostRecovery": {
      "title": "Cost Recovery Charge",
      "description": "Represents monthly extra costs calculated per CBM.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "totalExtraCost": { "type": "number" },
        "totalCbm": { "type": "number" },
        "costPerCbm": { "type": "number" },
        "sellingPricePerCbm": { "type": "number" }
      },
      "required": ["id", "startDate", "endDate"]
    },
    "Location": {
      "title": "Location",
      "description": "Location for Pickup and Delivery",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "isOutskirt": { "type": "boolean" }
      },
      "required": ["id", "name"]
    },
    "MiscChargeType": {
      "title": "Misc Charge Type",
      "description": "Types of miscellaneous charges",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "MasterTariff": {
      "title": "Master Tariff",
      "description": "Represents tariffs grouped by type.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tariffType": { "type": "string" },
        "pol": { "type": "string" },
        "pod": { "type": "string" },
        "locationFrom": { "type": "string" },
        "locationTo": { "type": "string" },
        "miscChargeTypeId": { "type": "string" },
        "rates": { "type": "array" }
      },
      "required": ["id", "tariffType", "name"]
    }
  },
  "firestore": {
    "receipts": { "schema": "Receipt", "description": "Shipment Stock-in records" },
    "returns": { "schema": "Return", "description": "Stock return records" },
    "pickups": { "schema": "Pickup", "description": "Pickup request records" },
    "manifests": { "schema": "Manifest", "description": "Loading manifests" },
    "companies": { "schema": "Company", "description": "Business partners master data" },
    "ports": { "schema": "Port", "description": "Ports master data" },
    "depots": { "schema": "Depot", "description": "Container depots master data" },
    "users": { "schema": "User", "description": "System users master data" },
    "roles": { "schema": "Role", "description": "User roles and permissions" },
    "warehouses": { "schema": "Warehouse", "description": "Warehouses master data" },
    "containerTypes": { "schema": "ContainerType", "description": "Container types master data" },
    "fclTemplates": { "schema": "FclTemplate", "description": "FCL cost templates" },
    "containerBookings": { "schema": "ContainerBooking", "description": "Container bookings with shipping lines" },
    "haulierBookings": { "schema": "HaulierBooking", "description": "Haulier bookings" },
    "commercialInvoices": { "schema": "CommercialInvoice", "description": "Commercial invoices" },
    "activityLogs": { "schema": "ActivityLog", "description": "System activity audit trail" },
    "notifications": { "schema": "Notification", "description": "User notifications" },
    "breakbulks": { "schema": "Breakbulk", "description": "Breakbulk (split) shipment records" },
    "storageZones": { "schema": "StorageZone", "description": "Warehouse storage zone allocation" },
    "storageRates": { "schema": "StorageRate", "description": "Storage pricing rates" },
    "storageEntries": { "schema": "StorageEntry", "description": "Storage service stock entries" },
    "vendorBills": { "schema": "VendorBill", "description": "Vendor billing attached to manifests" },
    "costRecoveries": { "schema": "CostRecovery", "description": "Extra costs recovered over time periods" },
    "masterTariffs": { "schema": "MasterTariff", "description": "Customer specific tariff rates by type" },
    "locations": { "schema": "Location", "description": "Locations for pickup and delivery" },
    "miscChargeTypes": { "schema": "MiscChargeType", "description": "Types of misc charges" },
    "system": { "schema": "object", "description": "System configuration and counters" }
  }
}
